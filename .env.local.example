# Telegram Bot Configuration
# Get your bot token from BotFather on Telegram: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Get your chat ID by sending a message to your bot and calling:
# https://api.telegram.org/botYOUR_TOKEN/getUpdates
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional: Public versions (for demo purposes only)
NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=your_bot_token_here
NEXT_PUBLIC_TELEGRAM_CHAT_ID=your_chat_id_here
